{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "startCommand": "gunicorn -w 4 -b 0.0.0.0:$PORT app:app",
  "rootDir": "backend"
}
