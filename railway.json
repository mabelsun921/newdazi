{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "providers": ["python"]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "startCommand": "cd backend && pip install -r requirements.txt && gunicorn -w 4 -b 0.0.0.0:$PORT app:app"
}
